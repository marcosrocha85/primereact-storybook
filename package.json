{
  "name": "sakai-storybook",
  "version": "0.0.1",
  "description": "Storybook design system documentation for PrimeFaces Sakai React.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
